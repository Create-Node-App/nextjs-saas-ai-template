#!/usr/bin/env bash

# ============================================================================
# Agentic A8n Hub - Dev Environment Configuration Template
# ============================================================================
# USAGE:
#   cp .envrc.dev.example .envrc
#   direnv allow
#
# This file is used by direnv to automatically load environment variables
# when you enter the project directory.
#
# DevContainer users: This is done automatically on container creation!
#
# If a .env.local file exists, it will be loaded and can override these
# defaults. Use .env.local for secrets (API keys, etc.) that shouldn't
# be in .envrc.
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================

# Node environment
# Values: development, test, production
export NODE_ENV="${NODE_ENV:-development}"

# Application URL (used by Next.js and Auth.js)
export NEXT_PUBLIC_APP_URL="${NEXT_PUBLIC_APP_URL:-http://localhost:3000}"

# Application name
export NEXT_PUBLIC_APP_NAME="${NEXT_PUBLIC_APP_NAME:-Agentic A8n Hub}"

# ============================================================================
# Database Configuration (PostgreSQL + pgvector)
# ============================================================================

# Database connection URL
# DevContainer: postgresql://a8nhub:a8nhub@db:5432/a8n_hub_dev
# Local Docker: postgresql://a8nhub:a8nhub@localhost:5432/a8n_hub_dev
# Production: Use a managed PostgreSQL with pgvector support (Neon, Supabase, etc.)
export DATABASE_URL="${DATABASE_URL:-postgresql://a8nhub:a8nhub@localhost:5432/a8n_hub_dev}"

# ============================================================================
# Authentication (Auth.js v5)
# ============================================================================

# Secret for signing tokens (min 32 characters)
# Generate with: openssl rand -base64 32
# This default is for development only - NEVER use in production!
export AUTH_SECRET="${AUTH_SECRET:-development-secret-change-in-production-min32chars}"

# Optional: Override the canonical URL (auto-detected in most cases)
# export AUTH_URL=https://a8n-hub.example.com

# Auth0 Provider (optional - for SSO)
export AUTH0_CLIENT_ID="${AUTH0_CLIENT_ID:-}"
export AUTH0_CLIENT_SECRET="${AUTH0_CLIENT_SECRET:-}"
export AUTH0_ISSUER="${AUTH0_ISSUER:-}"

# ============================================================================
# AI / LLM Configuration
# ============================================================================

# OpenAI API key (for GPT models and embeddings)
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"

# Anthropic API key (for Claude models)
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"

# Enable AI features (set to true when API keys are configured)
export ENABLE_AI_FEATURES="${ENABLE_AI_FEATURES:-false}"

# ============================================================================
# AWS Configuration (optional)
# ============================================================================

export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-}"
export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-}"
export AWS_REGION="${AWS_REGION:-us-east-1}"
export AWS_S3_BUCKET="${AWS_S3_BUCKET:-}"

# S3-compatible storage (MinIO for local dev)
# S3_ENDPOINT: Internal endpoint for server-side operations (e.g., http://minio:9000)
# S3_PUBLIC_ENDPOINT: Browser-accessible endpoint for presigned URLs (e.g., http://localhost:9000)
export S3_ENDPOINT="${S3_ENDPOINT:-}"
export S3_PUBLIC_ENDPOINT="${S3_PUBLIC_ENDPOINT:-}"

# ============================================================================
# Observability (optional)
# ============================================================================

export SENTRY_DSN="${SENTRY_DSN:-}"
export NEXT_PUBLIC_SENTRY_DSN="${NEXT_PUBLIC_SENTRY_DSN:-}"

# ============================================================================
# Load Environment Variables from .env.local (Optional Overrides)
# ============================================================================
# If a .env.local file exists, it will be loaded and can override the defaults
# defined above. This allows for machine-specific configuration without
# modifying this .envrc file.
#
# To create overrides: cp .env.example .env.local
# See .env.example for detailed documentation of each variable.

if [[ -f .env.local ]]; then
  echo "📄 Loading environment overrides from .env.local..."
  set -a
  source .env.local
  set +a
elif [[ -f .env ]]; then
  echo "📄 Loading environment overrides from .env..."
  set -a
  source .env
  set +a
else
  echo "💡 Tip: Create .env.local from .env.example to customize configuration (optional)"
fi

# ============================================================================
# Node.js Environment Setup
# ============================================================================

# Use pnpm as the package manager
export npm_config_engine_strict=true

# Detect if running in DevContainer
if [[ -n "${REMOTE_CONTAINERS}" ]] || [[ -n "${CODESPACES}" ]]; then
  echo "🐳 Running in DevContainer/Codespaces..."
  # Use container hostname for database
  export DATABASE_URL="${DATABASE_URL:-postgresql://a8nhub:a8nhub@db:5432/a8n_hub_dev}"
fi

# Check for pnpm
if ! command -v pnpm > /dev/null 2>&1; then
  echo "⚠️  pnpm not found. Install with: npm install -g pnpm"
fi

# ============================================================================
# Helpful Commands
# ============================================================================

echo ""
echo "🚀 Agentic A8n Hub - Available Commands:"
echo "  pnpm dev          - Start development server (port 3000)"
echo "  pnpm build        - Build for production"
echo "  pnpm lint         - Run ESLint"
echo "  pnpm type-check   - Run TypeScript check"
echo "  pnpm test         - Run tests"
echo "  pnpm db:push      - Push schema to database"
echo "  pnpm db:studio    - Open Drizzle Studio (port 5555)"
echo "  pnpm db:generate  - Generate migrations"
echo "  pnpm db:migrate   - Run migrations"
echo ""
echo "📚 Documentation: See docs/ folder for guides"
echo ""
